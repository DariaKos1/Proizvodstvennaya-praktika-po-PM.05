<Window x:Class="ElectroVypApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Электровыпрямитель - Главная" Height="600" Width="900">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Menu Grid.Row="0" Margin="0,0,0,10">
            <MenuItem Header="Файл">
                <MenuItem Header="Выход" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="Справочники">
                <MenuItem Header="Товары" Click="Products_Click"/>
                <MenuItem Header="Виды продукции" Click="ProductTypes_Click"/>
            </MenuItem>
            <MenuItem Header="Отчеты">
                <MenuItem Header="История расчетов" Click="History_Click"/>
            </MenuItem>
            <MenuItem Header="Помощь">
                <MenuItem Header="О программе" Click="About_Click"/>
            </MenuItem>
        </Menu>

        <DataGrid x:Name="grid" AutoGenerateColumns="False" Grid.Row="1" SelectionChanged="grid_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Код" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Товар" Binding="{Binding Name}" Width="250"/>
                <DataGridTextColumn Header="Тип" Binding="{Binding Type}" Width="150"/>
                <DataGridTextColumn Header="Мощность (кВт)" Binding="{Binding PowerKw}" Width="100"/>
                <DataGridTextColumn Header="Цена (руб)" Binding="{Binding Price, StringFormat=N2}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="2" BorderBrush="#2C3E50" BorderThickness="1" Padding="10" Margin="0,10,0,0" Background="#ECF0F1">
            <StackPanel>
                <TextBlock Text="Расчет стоимости" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Количество:" VerticalAlignment="Center" Margin="5"/>
                    <TextBox x:Name="txtQuantity" Grid.Column="1" Width="100" Margin="5" Text="1"/>
                    <Button x:Name="btnCalculate" Grid.Column="2" Content="Рассчитать" Width="100" Margin="5" Click="btnCalculate_Click" Background="#3498DB" Foreground="White"/>
                    <Button x:Name="btnRefresh" Grid.Column="3" Content="Обновить" Width="100" Margin="5" Click="btnRefresh_Click" Background="#95A5A6" Foreground="White"/>
                </Grid>
                <TextBlock x:Name="tbResult" FontSize="18" FontWeight="Bold" Margin="5,10,5,0" HorizontalAlignment="Center" Foreground="#2C3E50"/>
            </StackPanel>
        </Border>

        <StatusBar Grid.Row="3" Margin="0,10,0,0">
            <StatusBarItem>
                <TextBlock x:Name="tbStatus" Text="Готов" Foreground="Gray"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>