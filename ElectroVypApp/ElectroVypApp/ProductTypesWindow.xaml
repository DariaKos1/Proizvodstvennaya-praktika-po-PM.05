<Window x:Class="ElectroVypApp.ProductTypesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Виды продукции" Height="350" Width="500">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DataGrid x:Name="grid" AutoGenerateColumns="False" Grid.Row="0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Код" Binding="{Binding Code}" Width="100"/>
                <DataGridTextColumn Header="Наименование" Binding="{Binding Name}" Width="250"/>
                <DataGridTextColumn Header="Базовая ставка" Binding="{Binding BaseRate, StringFormat=N2}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <Button x:Name="btnClose" Grid.Row="1" Content="Закрыть" Width="100" Height="30" Margin="0,10,0,0" Click="btnClose_Click"/>
    </Grid>
</Window>