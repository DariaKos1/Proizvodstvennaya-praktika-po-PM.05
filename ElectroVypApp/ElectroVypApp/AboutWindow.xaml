<Window x:Class="ElectroVypApp.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="О программе" Height="250" Width="400" WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="ПАО &quot;Электровыпрямитель&quot;" FontSize="18" FontWeight="Bold" TextAlignment="Center"/>
            <TextBlock Text="г. Саранск" FontSize="14" Margin="0,5,0,0" TextAlignment="Center"/>
            <TextBlock Text="Программа для расчета стоимости продукции" FontSize="12" Margin="0,20,0,0" TextAlignment="Center"/>
            <TextBlock Text="Версия 1.0" FontSize="11" Margin="0,10,0,0" TextAlignment="Center" Foreground="Gray"/>
            <TextBlock FontSize="11" Margin="0,5,0,0" TextAlignment="Center" Foreground="Gray"><Run Language="ru-ru" Text="2026"/></TextBlock>
            <Button x:Name="btnOk" Content="OK" Width="100" Height="30" Margin="0,30,0,0" Click="btnOk_Click"/>
        </StackPanel>
    </Grid>
</Window>