<Window x:Class="ElectroVypApp.ProductsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление товарами" Height="450" Width="700">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DataGrid x:Name="grid" AutoGenerateColumns="False" Grid.Row="0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Код" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Товар" Binding="{Binding Name}" Width="200"/>
                <DataGridTextColumn Header="Тип" Binding="{Binding Type}" Width="120"/>
                <DataGridTextColumn Header="Мощность" Binding="{Binding PowerKw}" Width="80"/>
                <DataGridTextColumn Header="Цена" Binding="{Binding Price, StringFormat=N2}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
            <Button x:Name="btnAdd" Content="Добавить" Width="100" Margin="5" Click="btnAdd_Click" Background="#27AE60" Foreground="White"/>
            <Button x:Name="btnEdit" Content="Изменить" Width="100" Margin="5" Click="btnEdit_Click" Background="#F39C12" Foreground="White"/>
            <Button x:Name="btnDelete" Content="Удалить" Width="100" Margin="5" Click="btnDelete_Click" Background="#E74C3C" Foreground="White"/>
            <Button x:Name="btnClose" Content="Закрыть" Width="100" Margin="5" Click="btnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>