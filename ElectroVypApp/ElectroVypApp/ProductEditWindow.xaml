<Window x:Class="ElectroVypApp.ProductEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Товар" Height="350" Width="400">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Наименование:" Margin="5"/>
        <TextBox x:Name="txtName" Grid.Row="1" Margin="5" Height="30"/>

        <TextBlock Text="Тип продукции:" Grid.Row="2" Margin="5"/>
        <ComboBox x:Name="cmbType" Grid.Row="3" Margin="5" Height="30">
            <ComboBoxItem Content="Полупроводниковый"/>
            <ComboBoxItem Content="Преобразователь"/>
            <ComboBoxItem Content="Оборудование"/>
            <ComboBoxItem Content="Комплектующие"/>
        </ComboBox>

        <TextBlock Text="Мощность (кВт):" Grid.Row="4" Margin="5"/>
        <TextBox x:Name="txtPower" Grid.Row="5" Margin="5" Height="30"/>

        <TextBlock Text="Цена (руб):" Grid.Row="6" Margin="5"/>
        <TextBox x:Name="txtPrice" Grid.Row="7" Margin="5" Height="30"/>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,73,0,0">
            <Button x:Name="btnSave" Content="Сохранить" Width="100" Margin="5" Click="btnSave_Click" Background="#27AE60" Foreground="White" Height="31"/>
            <Button x:Name="btnCancel" Content="Отмена" Width="100" Margin="5" Click="btnCancel_Click" Height="31"/>
        </StackPanel>
    </Grid>
</Window>